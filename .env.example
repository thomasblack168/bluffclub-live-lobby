# Postgres (Supabase): use the "Transaction" pooler URL for Prisma in serverless.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"

# Auth.js / NextAuth — required in production
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Supabase project (Realtime + anon reads on lobby)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional: service role (not required for this app; mutations use Prisma + DATABASE_URL)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# First staff user (prisma db seed)
SEED_STAFF_PASSWORD="changeme"
