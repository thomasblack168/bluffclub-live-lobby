# Postgres (Supabase)
# Runtime (Vercel / Next server): Transaction pooler, port 6543.
# Include ?pgbouncer=true so Prisma avoids prepared-statement errors on the pooler.
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations (local / CI): Direct connection, port 5432 — required for `prisma migrate deploy`.
DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# Auth.js / NextAuth — required in production
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Must match the origin you open in the browser (scheme + host + port). If `next dev`
# prints "Port 3000 is in use, using 3002", either free port 3000 or set AUTH_URL to
# http://localhost:3002. For local dev you may omit AUTH_URL entirely (trustHost in
# auth.config.ts); Auth.js will use the Host header so redirects follow the actual port.
AUTH_URL="http://localhost:3000"

# Supabase project (Realtime + anon reads on lobby)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional: service role (not required for this app; mutations use Prisma + DATABASE_URL)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# First staff user (prisma db seed)
SEED_STAFF_PASSWORD="changeme"

# Prisma: when DIRECT_URL is set and VERCEL is not "1", the app uses DIRECT_URL at runtime
# (avoids Supabase :6543 transaction pooler + prepared-statement errors with Turbopack).
# On Vercel, DATABASE_URL (pooler + ?pgbouncer=true) is used. To force the pooler locally:
# PRISMA_FORCE_POOLER=1
# (alias: PRISMA_DEV_USE_POOLER=1)

# Optional: Upstash Redis — enables credentials sign-in rate limiting in middleware.
# If unset, rate limiting is skipped (fine for local dev). Alternative: use a WAF
# (e.g. Cloudflare) or your host’s firewall for abuse protection instead.
# UPSTASH_REDIS_REST_URL="https://....upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."
